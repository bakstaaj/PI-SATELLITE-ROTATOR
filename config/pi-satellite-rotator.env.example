# pi-satellite-rotator systemd environment file.
#
# Installed path:
#   /etc/pi-satellite-rotator/pi-satellite-rotator.env
#
# Parked safe no-motion mode:
# - EasyComm TCP server on port 4553
# - Web UI on HTTP port 8080
# - WT901 feedback enabled
# - GPIO motor backend disabled until the rotator is mechanically assembled
# - Measured elevation may go negative before the lower limit switch establishes true zero
#
# Validated WT901 bench mapping:
# - Azimuth feedback: yaw
# - Azimuth offset: 270.00
# - Elevation feedback: roll
# - Elevation offset: 14.60
# - Elevation inversion: normal / no --el-invert
PI_SATELLITE_ROTATOR_ARGS="--port 4553 --web-port 8080 --feedback-timeout-ms 1000 --sensor /dev/serial/by-id/usb-1a86_USB_Serial-if00-port0 --sensor-baud 115200 --motor-backend simulator --az-axis yaw --az-offset 270.00 --el-axis roll --el-offset 14.60"

# To disable the integrated web server:
# PI_SATELLITE_ROTATOR_ARGS="--port 4553 --no-web"

# GPIO motor backend example.
# WARNING: opt in only after mechanical assembly, limit switches, and motor direction checks.
# Keep WT901 feedback enabled when using GPIO motor control.
#
# PI_SATELLITE_ROTATOR_ARGS="--port 4553 --web-port 8080 --feedback-timeout-ms 1000 --sensor /dev/serial/by-id/usb-1a86_USB_Serial-if00-port0 --sensor-baud 115200 --az-axis yaw --az-offset 270.00 --el-axis roll --el-offset 14.60 --motor-backend gpio"
#
# If motor direction is reversed:
#   add --az-motor-invert and/or --el-motor-invert
