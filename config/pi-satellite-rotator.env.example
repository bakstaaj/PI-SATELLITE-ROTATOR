# pi-satellite-rotator systemd environment file.
#
# Installed path:
#   /etc/pi-satellite-rotator/pi-satellite-rotator.env
#
# Default safe simulator mode. The service exposes EasyComm on TCP 4553
# and the web control page on HTTP 8080.
PI_SATELLITE_ROTATOR_ARGS=--port 4553 --web-port 8080 --feedback-timeout-ms 1000

# Live WT901 USB feedback example. Replace the serial path with your actual
# /dev/serial/by-id/... device path after running:
#   ls -l /dev/serial/by-id/ /dev/ttyUSB*
#
# PI_SATELLITE_ROTATOR_ARGS=--port 4553 --web-port 8080 --feedback-timeout-ms 1000 --sensor /dev/serial/by-id/usb-WitMotion_SENSOR-if00 --sensor-baud 115200 --az-axis yaw --el-axis roll
#
# To disable the integrated web server:
# PI_SATELLITE_ROTATOR_ARGS=--port 4553 --no-web

# GPIO motor backend example. This is opt-in and requires WT901 feedback.
# Confirm direction with the motors mechanically unloaded first.
#
# PI_SATELLITE_ROTATOR_ARGS=--port 4553 --web-port 8080 --feedback-timeout-ms 1000 --sensor /dev/serial/by-id/usb-WitMotion_SENSOR-if00 --sensor-baud 115200 --az-axis yaw --el-axis roll --motor-backend gpio
#
# If motor direction is reversed:
#   add --az-motor-invert and/or --el-motor-invert

# GPIO backend note:
# --motor-backend gpio requires the pinctrl command on Raspberry Pi OS.

# GPIO backend no-motion validation:
# Enable --motor-backend gpio only after WT901 feedback is validated and the
# rotator/motors are mechanically safe. The service user requires gpio group
# access because the GPIO backend uses Raspberry Pi pinctrl.

